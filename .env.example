# Скопируй в .env: cp .env.example .env

# PostgreSQL
POSTGRES_VERSION=18.2-alpine
POSTGRES_DB=aggregator
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me

# Ollama
OLLAMA_URL=http://ollama:11434
